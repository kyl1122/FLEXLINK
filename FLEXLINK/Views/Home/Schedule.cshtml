@using FLEXLINK.Models
@model IEnumerable<FLEXLINK.Models.TrainerSchedule>
@{
    ViewData["Title"] = "My Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var trainerProfiles = ViewBag.TrainerProfiles as List<ProfileTrainer> ?? new();
    var userRatings = ViewBag.UserRatings as List<TrainerRating> ?? new();
    var allRatings = ViewBag.AllRatings as List<TrainerRating> ?? new();
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">My Booked Sessions</h2>
        <p class="text-muted">These are the sessions you have personally booked with a trainer.</p>
    </div>

    @if (TempData["RatingSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i> @TempData["RatingSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded" style="background:#f9f9f9;">
            <p class="text-muted fs-5 mb-3">You have no booked sessions yet.</p>
            <a asp-controller="Home" asp-action="Trainer" class="btn btn-primary">
                Browse Trainers & Book a Session
            </a>
        </div>
    }
    else
    {
        @foreach (var dateGroup in Model.GroupBy(s => s.ScheduleDate.Date))
        {
            <div class="mb-4">
                <h5 class="fw-bold text-primary border-bottom pb-2">
                    @dateGroup.Key.ToString("dddd, MMMM dd, yyyy")
                </h5>
                <div class="row g-3">
                    @foreach (var s in dateGroup)
                    {
                        @* Find this trainer's profile *@
                        var profile = trainerProfiles.FirstOrDefault(p => p.FullName == s.TrainerName);
                        var myRating = profile != null
                            ? userRatings.FirstOrDefault(r => r.TrainerId == profile.Id)
                            : null;
                        var trainerAllRatings = profile != null
                            ? allRatings.Where(r => r.TrainerId == profile.Id).ToList()
                            : new();
                        double avg = trainerAllRatings.Any() ? Math.Round(trainerAllRatings.Average(r => r.Stars), 1) : 0;
                        int cnt = trainerAllRatings.Count;

                        var rateModalId = "schedRateModal_" + (profile?.Id ?? 0) + "_" + s.Id;

                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="fw-bold mb-1">
                                        <i class="bi bi-person-fill text-primary me-1"></i>
                                        @s.TrainerName
                                    </h6>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-clock me-1"></i>
                                        @DateTime.Today.Add(s.StartTime).ToString("hh:mm tt") —
                                        @DateTime.Today.Add(s.EndTime).ToString("hh:mm tt")
                                    </p>
                                    @if (!string.IsNullOrEmpty(s.Notes))
                                    {
                                        <p class="text-muted small mb-1">
                                            <i class="bi bi-journal-text me-1"></i> @s.Notes
                                        </p>
                                    }
                                    <span class="badge text-bg-success mt-1 mb-3" style="width:fit-content;">
                                        <i class="bi bi-check-circle me-1"></i>Booked
                                    </span>

                                    @* ── Rating summary ── *@
                                    <div class="mt-auto">
                                        <div class="d-flex align-items-center gap-1 mb-1">
                                            @{
                                                int fullStars = (int)Math.Floor(avg);
                                                bool halfStar = (avg - fullStars) >= 0.5;
                                            }
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= fullStars)
                                                {
                                                    <i class="bi bi-star-fill" style="color:#f5a623; font-size:0.85rem;"></i>
                                                }
                                                else if (i == fullStars + 1 && halfStar)
                                                {
                                                    <i class="bi bi-star-half" style="color:#f5a623; font-size:0.85rem;"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star" style="color:#ccc; font-size:0.85rem;"></i>
                                                }
                                            }
                                            <span class="text-muted" style="font-size:0.75rem;">
                                                @if (cnt == 0)
                                                {
                                                    <text>No ratings yet</text>
                                                }
                                                else
                                                {

                                                    <text>@avg / 5 · @cnt rated</text>
                                                }
                                            </span>
                                        </div>

                                        @* Rate button — only if we found a trainer profile *@
                                        @if (profile != null)
                                        {
                                            <button class="btn btn-outline-warning btn-sm w-100 mt-1"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#@rateModalId">
                                                <i class="bi bi-star me-1"></i>
                                                @(myRating != null ? $"Update Rating ({myRating.Stars}★)" : "Rate Trainer")
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* ── Rating modal for this card ── *@
                        @if (profile != null)
                        {
                            <div class="modal fade" id="@rateModalId" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered modal-sm">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Rate @s.TrainerName</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-controller="Home" asp-action="RateTrainer" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="trainerId" value="@profile.Id" />
                                            <input type="hidden" name="stars" class="star-value-sched-@profile.Id-@s.Id" value="@(myRating?.Stars ?? 0)" />

                                            <div class="modal-body text-center">
                                                <p class="text-muted small mb-3">Rate your experience with @s.TrainerName</p>
                                                <div class="star-rating-sched d-inline-flex gap-2"
                                                     data-trainer-id="@profile.Id"
                                                     data-sched-id="@s.Id">
                                                    @for (int st = 1; st <= 5; st++)
                                                    {
                                                        <i class="bi @(st <= (myRating?.Stars ?? 0) ? "bi-star-fill" : "bi-star") star-btn-sched"
                                                           data-value="@st"
                                                           style="font-size:2rem; cursor:pointer; color:@(st <= (myRating?.Stars ?? 0) ? "#f5a623" : "#ccc"); transition:color 0.1s;"></i>
                                                    }
                                                </div>
                                                <p class="mt-2 mb-0 text-muted small sched-star-label-@profile.Id-@s.Id">
                                                    @(myRating != null ? $"Your rating: {myRating.Stars}★" : "Click a star to rate")
                                                </p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-warning btn-sm sched-submit-@profile.Id-@s.Id" @(myRating != null ? "" : "disabled")>
                                                    <i class="bi bi-check2 me-1"></i> Submit
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        const schedLabels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];

        document.querySelectorAll('.star-rating-sched').forEach(function (container) {
            const trainerId = container.dataset.trainerId;
            const schedId   = container.dataset.schedId;
            const key       = trainerId + '-' + schedId;
            const stars     = container.querySelectorAll('.star-btn-sched');
            const hidden    = document.querySelector('.star-value-sched-' + key);
            const label     = document.querySelector('.sched-star-label-' + key);
            const submit    = document.querySelector('.sched-submit-' + key);

            function paint(n) {
                stars.forEach(function (s, i) {
                    s.className = 'bi ' + (i < n ? 'bi-star-fill' : 'bi-star') + ' star-btn-sched';
                    s.style.color = i < n ? '#f5a623' : '#ccc';
                });
            }

            stars.forEach(function (star) {
                star.addEventListener('mouseenter', function () {
                    paint(parseInt(star.dataset.value));
                    label.textContent = schedLabels[parseInt(star.dataset.value)];
                });
                star.addEventListener('mouseleave', function () {
                    const cur = parseInt(hidden.value) || 0;
                    paint(cur);
                    label.textContent = cur > 0 ? 'Your rating: ' + cur + '★' : 'Click a star to rate';
                });
                star.addEventListener('click', function () {
                    const val = parseInt(star.dataset.value);
                    hidden.value = val;
                    paint(val);
                    label.textContent = schedLabels[val] + ' (' + val + '★)';
                    submit.disabled = false;
                });
            });
        });
    </script>
}
