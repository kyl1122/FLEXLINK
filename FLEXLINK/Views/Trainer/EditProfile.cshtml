@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <div class="mx-auto mb-3">
                    <img src="~/images/download.jng"
                         alt="Trainer Profile Picture"
                         class="rounded-circle shadow-sm"
                         style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #0d6efd;" />
                </div>
        
                <h4 class="fw-bold">@User.Identity.Name</h4>
                <p class="text-muted">Certified Fitness Trainer</p>
                <hr />
                <div class="text-start small">
                    <p><strong>Status:</strong> <span class="badge bg-success">Active</span></p>
                    <p><strong>Member Since:</strong> 2026</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4">
                <h3 class="mb-4">My Professional Profile</h3>
                <form asp-action="UpdateProfile" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" class="form-control" placeholder="Coach Name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Specialization</label>
                            <select class="form-select">
                                <option>Weight Loss</option>
                                <option>Bodybuilding</option>
                                <option>Yoga & Flexibility</option>
                                <option>Cardio Kickboxing</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Bio / Professional Summary</label>
                        <textarea class="form-control" rows="4" placeholder="Tell users about your experience..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Areas of Expertise (Tags)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tags"></i></span>
                            <input type="text" class="form-control" placeholder="e.g. HIIT, Nutrition, Strength" />
                        </div>
                        <div class="form-text">Separate expertise with commas.</div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Save Profile Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>