@using FLEXLINK.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Staff Check-In";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int currentCount = ViewBag.CurrentCount;
    int maxCapacity = ViewBag.MaxCapacity;
    bool isFull = ViewBag.IsFull;
    double percent = maxCapacity > 0 ? Math.Round((double)currentCount / maxCapacity * 100, 0) : 0;
}

<div class="container mt-4" style="max-width: 600px;">

    <div class="mb-4 text-center">
        <h2 class="fw-bold mb-0">Staff Check-In</h2>
        <p class="text-muted">Check in members or guests as they arrive at the gym.</p>
    </div>

    @* ── Alerts ── *@
    @if (TempData["AttendanceSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i> @TempData["AttendanceSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["AttendanceError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["AttendanceError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Space Capacity ── *@
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-semibold"><i class="bi bi-people-fill me-1"></i>Space Capacity</span>
                <span class="fw-bold @(isFull ? "text-danger" : "text-success")">
                    @currentCount / @maxCapacity
                </span>
            </div>
            <div class="progress" style="height: 18px; border-radius: 10px;">
                <div class="progress-bar @(isFull ? "bg-danger" : "bg-success")"
                     role="progressbar"
                     style="width: @percent%;"
                     aria-valuenow="@currentCount" aria-valuemin="0" aria-valuemax="@maxCapacity">
                </div>
            </div>
            @if (isFull)
            {
                <p class="text-danger small mt-2 mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    Gym is at full capacity. No further check-ins are allowed until space frees up.
                </p>
            }
        </div>
    </div>

    @* ── Member Login (Attendance) ── *@
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
        <div class="card-body">
            <h5 class="fw-bold mb-3"><i class="bi bi-box-arrow-in-right me-1"></i>Member Login</h5>
            <form asp-controller="Staff" asp-action="MemberLogin" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="member@email.com" />
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="Password" />
                </div>
                <button type="submit" class="btn btn-primary w-100" @(isFull ? "disabled" : "")>
                    <i class="bi bi-door-open me-1"></i> Login &amp; Check In
                </button>
            </form>
        </div>
    </div>

    @* ── Guest Login (Attendance) ── *@
    <div class="card border-0 shadow-sm mb-4" style="border-radius:14px;">
        <div class="card-body text-center">
            <h5 class="fw-bold mb-2"><i class="bi bi-person-badge me-1"></i>No Account?</h5>
            <p class="text-muted small mb-3">Walk-in guests can check in without registering.</p>
            <form asp-controller="Staff" asp-action="GuestLogin" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary w-100" @(isFull ? "disabled" : "")>
                    <i class="bi bi-person-plus me-1"></i> Login as Guest
                </button>
            </form>
        </div>
    </div>

</div>
