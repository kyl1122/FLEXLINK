@{
    ViewData["Title"] = "Membership Plans";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Choose Your Plan</h1>
        <p class="lead text-muted">Select the membership that fits your fitness goals.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 text-center">
                    <h4 class="my-0 fw-normal">1 Month</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">300php</h1>
                    <button type="button" class="btn btn-lg btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#confirmPlan1">Get Started</button>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow border-primary border-2">
                <div class="card-header py-3 bg-primary text-white border-primary text-center">
                    <h4 class="my-0 fw-normal">2 Months</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">550php</h1>
                    <button type="button" class="btn btn-lg btn-primary w-100" data-bs-toggle="modal" data-bs-target="#confirmPlan2">Most Popular</button>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 text-center">
                    <h4 class="my-0 fw-normal">3 Months</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">800php</h1>
                    <button type="button" class="btn btn-lg btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#confirmPlan3">Go Elite</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmPlan1" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">Confirm Purchase</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <h5>You selected the <strong>1 Month Plan</strong></h5>
                <p class="text-muted">Total amount due: <strong>300php</strong></p>
                <p class="small text-secondary">Proceeding will activate this plan for your FLEXLINK account.</p>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a asp-controller="Home" asp-action="Subscribe" asp-route-months="1" class="btn btn-primary px-4">Confirm & Pay</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmPlan2" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">Confirm Purchase</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <h5>You selected the <strong>2 Months Plan</strong></h5>
                <p class="text-muted">Total amount due: <strong>550php</strong></p>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a asp-controller="Home" asp-action="Subscribe" asp-route-months="2" class="btn btn-primary px-4">Confirm & Pay</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmPlan3" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">Confirm Purchase</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <h5>You selected the <strong>3 Months Plan</strong></h5>
                <p class="text-muted">Total amount due: <strong>800php</strong></p>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a asp-controller="Home" asp-action="Subscribe" asp-route-months="3" class="btn btn-primary px-4">Confirm & Pay</a>
            </div>
        </div>
    </div>
</div>