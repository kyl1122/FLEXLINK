@model IEnumerable<FLEXLINK.Models.TrainerSchedule>
@{
    ViewData["Title"] = "My Schedule";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">My Booked Sessions</h2>
        <p class="text-muted">These are the sessions you have personally booked with a trainer.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded" style="background:#f9f9f9;">
            <p class="text-muted fs-5 mb-3">You have no booked sessions yet.</p>
            <a asp-controller="Home" asp-action="Trainer" class="btn btn-primary">
                Browse Trainers & Book a Session
            </a>
        </div>
    }
    else
    {
        @foreach (var dateGroup in Model.GroupBy(s => s.ScheduleDate.Date))
        {
            <div class="mb-4">
                <h5 class="fw-bold text-primary border-bottom pb-2">
                    @dateGroup.Key.ToString("dddd, MMMM dd, yyyy")
                </h5>
                <div class="row g-3">
                    @foreach (var s in dateGroup)
                    {
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                                <div class="card-body">
                                    <h6 class="fw-bold mb-1">
                                        <i class="bi bi-person-fill text-primary me-1"></i>
                                        @s.TrainerName
                                    </h6>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-clock me-1"></i>
                                        @DateTime.Today.Add(s.StartTime).ToString("hh:mm tt") —
                                        @DateTime.Today.Add(s.EndTime).ToString("hh:mm tt")
                                    </p>
                                    @if (!string.IsNullOrEmpty(s.Notes))
                                    {
                                        <p class="text-muted small mb-1">
                                            <i class="bi bi-journal-text me-1"></i> @s.Notes
                                        </p>
                                    }
                                    <span class="badge text-bg-success mt-1">
                                        <i class="bi bi-check-circle me-1"></i>Booked
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
