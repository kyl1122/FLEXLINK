@model IEnumerable<FLEXLINK.ViewModels.TrainerWithSchedulesViewModel>
@{
    ViewData["Title"] = "Our Trainers";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">Our Trainers</h2>
        <p class="text-muted">Choose a professional trainer and pick your preferred session slots.</p>
    </div>

    @* Global alerts *@
    @if (TempData["BookingSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i> @TempData["BookingSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["BookingError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle me-1"></i> @TempData["BookingError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["BookingConflict"] != null)
    {
        var conflicts = TempData["BookingConflict"].ToString().Split('|');
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>
            <strong>Schedule Conflict Detected:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var msg in conflicts)
                {
                    <li>@msg</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">No trainers are available yet. Check back soon!</p>
        </div>
    }
    else
    {
        <div class="row g-4 align-items-stretch">
            @foreach (var vm in Model)
            {
                var trainer = vm.Trainer;
                var schedules = vm.AvailableSchedules;
                var modalId = "scheduleModal_" + trainer.Id;
                var rateModalId = "rateModal_" + trainer.Id;

                <div class="col-md-4 d-flex">
                    <div class="card shadow-sm border-0 w-100"
                         style="border-radius:16px; overflow:hidden; display:flex; flex-direction:column;">

                        @* ── Top: Profile info ── *@
                        <div class="text-center pt-4 px-3">
                            <img src="@(trainer.ProfilePicture ?? "/uploads/DefaultProfile.png")"
                                 alt="@trainer.FullName"
                                 style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid #dee2e6;" />
                            <h5 class="fw-bold mt-2 mb-0">@trainer.FullName</h5>
                            <p class="text-muted small mb-0"><i class="bi bi-envelope me-1"></i>@trainer.Email</p>
                            @if (!string.IsNullOrEmpty(trainer.PhoneNumber))
                            {
                                <p class="text-muted small mb-0"><i class="bi bi-telephone me-1"></i>@trainer.PhoneNumber</p>
                            }
                            @if (!string.IsNullOrEmpty(trainer.Address))
                            {
                                <p class="text-muted small mb-0"><i class="bi bi-geo-alt me-1"></i>@trainer.Address</p>
                            }
                            @if (!string.IsNullOrEmpty(trainer.Expertise))
                            {
                                <p class="text-muted small mb-0"><i class="bi bi-trophy me-1"></i>@trainer.Expertise</p>
                            }
                        </div>

                        @* ── Middle: Scrollable schedule list ── *@
                        <div class="px-3 mt-3">
                            @if (schedules.Any())
                            {
                                <p class="fw-semibold small text-center mb-2">
                                    <i class="bi bi-calendar-check text-success me-1"></i>
                                    @schedules.Count Available Session@(schedules.Count != 1 ? "s" : "")
                                </p>
                                <div style="height:110px; overflow-y:auto; display:flex; flex-direction:column; gap:5px; padding-right:4px;">
                                    @foreach (var slot in schedules)
                                    {
                                        <div class="border rounded px-2 py-1 bg-light flex-shrink-0"
                                             style="font-size:0.76rem;">
                                            <i class="bi bi-clock text-primary me-1"></i>
                                            <strong>@slot.ScheduleDate.ToString("MMM dd")</strong>
                                            &nbsp;@DateTime.Today.Add(slot.StartTime).ToString("hh:mm tt") – @DateTime.Today.Add(slot.EndTime).ToString("hh:mm tt")
                                            @if (!string.IsNullOrEmpty(slot.Notes))
                                            {
                                                <span class="text-muted"> · @slot.Notes</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center my-2" style="height:110px; display:flex; align-items:center; justify-content:center;">
                                    <span class="badge text-bg-secondary px-3 py-2">
                                        <i class="bi bi-calendar-x me-1"></i> No available sessions
                                    </span>
                                </div>
                            }
                        </div>

                        @* ── Bottom: Book button ── *@
                        <div class="px-3 pb-2 pt-2">
                            @if (schedules.Any())
                            {
                                <button class="btn btn-primary w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#@modalId">
                                    <i class="bi bi-calendar-plus me-1"></i> Book a Session
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary w-100" disabled>
                                    No Sessions Available
                                </button>
                            }
                        </div>

                        @* ── Rating Section ── *@
                        <div class="px-3 pb-4 pt-1">
                            <hr class="my-2" />

                            @* Public rating summary — visible to everyone *@
                            <div class="text-center mb-2">
                                @{
                                    var fullStars = (int)Math.Floor(vm.AverageRating);
                                    var halfStar = (vm.AverageRating - fullStars) >= 0.5;
                                }
                                <div class="d-inline-flex align-items-center gap-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= fullStars)
                                        {
                                            <i class="bi bi-star-fill" style="color:#f5a623; font-size:1.1rem;"></i>
                                        }
                                        else if (i == fullStars + 1 && halfStar)
                                        {
                                            <i class="bi bi-star-half" style="color:#f5a623; font-size:1.1rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star" style="color:#ccc; font-size:1.1rem;"></i>
                                        }
                                    }
                                </div>
                                <div class="text-muted small mt-1">
                                    @if (vm.RatingCount == 0)
                                    {
                                        <span>No ratings yet</span>
                                    }
                                    else
                                    {
                                        <span><strong>@vm.AverageRating</strong> / 5 &nbsp;·&nbsp; @vm.RatingCount user@(vm.RatingCount != 1 ? "s" : "") rated</span>
                                    }
                                </div>
                            </div>

                            @* Rate button — only for logged-in users who have booked this trainer *@
                            @if (User.Identity?.IsAuthenticated == true && vm.CurrentUserHasBooked)
                            {
                                <button class="btn btn-outline-warning btn-sm w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#@rateModalId">
                                    <i class="bi bi-star me-1"></i>
                                    @(vm.CurrentUserRating.HasValue ? $"Update Your Rating ({vm.CurrentUserRating}★)" : "Rate This Trainer")
                                </button>
                            }
                        </div>
                    </div>
                </div>

                @* ── Per-Trainer Booking Modal ── *@
                @if (schedules.Any())
                {
                    <div class="modal fade" id="@modalId" tabindex="-1"
                         aria-labelledby="@(modalId)_label" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="@(modalId)_label">
                                        Book a Session with @trainer.FullName
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <form asp-controller="Home" asp-action="BookSchedules" method="post" class="booking-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="scheduleIds" class="selected-ids-input" value="" />

                                    <div class="modal-body">
                                        <p class="text-muted small mb-3">
                                            Select one or more sessions. You will be warned if any slot conflicts with an existing booking.
                                        </p>
                                        <div class="d-flex flex-column gap-2">
                                            @foreach (var slot in schedules)
                                            {
                                                <label class="schedule-slot d-flex align-items-start gap-3 border rounded p-3"
                                                       style="cursor:pointer; transition:background 0.15s;">
                                                    <input type="checkbox"
                                                           class="form-check-input schedule-checkbox mt-1 flex-shrink-0"
                                                           value="@slot.Id" />
                                                    <div class="flex-grow-1">
                                                        <div class="fw-semibold">
                                                            <i class="bi bi-calendar3 me-1 text-primary"></i>
                                                            @slot.ScheduleDate.ToString("dddd, MMMM dd, yyyy")
                                                        </div>
                                                        <div class="text-muted small">
                                                            <i class="bi bi-clock me-1"></i>
                                                            @DateTime.Today.Add(slot.StartTime).ToString("hh:mm tt") –
                                                            @DateTime.Today.Add(slot.EndTime).ToString("hh:mm tt")
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(slot.Notes))
                                                        {
                                                            <div class="text-muted small">
                                                                <i class="bi bi-journal-text me-1"></i> @slot.Notes
                                                            </div>
                                                        }
                                                    </div>
                                                    <span class="badge text-bg-success align-self-center">Available</span>
                                                </label>
                                            }
                                        </div>
                                    </div>

                                    <div class="modal-footer d-flex justify-content-between align-items-center">
                                        <span class="text-muted small selection-count">0 session(s) selected</span>
                                        <div>
                                            <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary confirm-book-btn" disabled>
                                                <i class="bi bi-check2-circle me-1"></i> Confirm Booking
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                @* ── Rating Modal ── *@
                @if (User.Identity?.IsAuthenticated == true && vm.CurrentUserHasBooked)
                {
                    <div class="modal fade" id="@rateModalId" tabindex="-1"
                         aria-labelledby="@(rateModalId)_label" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-sm">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="@(rateModalId)_label">
                                        Rate @trainer.FullName
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form asp-controller="Home" asp-action="RateTrainer" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="trainerId" value="@trainer.Id" />
                                    <input type="hidden" name="stars" class="star-value-input-@trainer.Id" value="@(vm.CurrentUserRating ?? 0)" />

                                    <div class="modal-body text-center">
                                        <p class="text-muted small mb-3">How would you rate your experience with this trainer?</p>
                                        <div class="star-rating d-inline-flex gap-2" data-trainer-id="@trainer.Id">
                                            @for (int s = 1; s <= 5; s++)
                                            {
                                                <i class="bi @(s <= (vm.CurrentUserRating ?? 0) ? "bi-star-fill" : "bi-star") star-btn"
                                                   data-value="@s"
                                                   style="font-size:2rem; cursor:pointer; color:@(s <= (vm.CurrentUserRating ?? 0) ? "#f5a623" : "#ccc"); transition:color 0.1s;"></i>
                                            }
                                        </div>
                                        <p class="mt-2 mb-0 text-muted small star-label-@trainer.Id">
                                            @(vm.CurrentUserRating.HasValue ? $"Your current rating: {vm.CurrentUserRating}★" : "Click a star to rate")
                                        </p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-warning btn-sm submit-rating-btn-@trainer.Id" @(vm.CurrentUserRating.HasValue ? "" : "disabled")>
                                            <i class="bi bi-check2 me-1"></i> Submit Rating
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // ── Booking modal logic ──────────────────────────────────────────────
        document.querySelectorAll('.booking-form').forEach(function (form) {
            const checkboxes = form.querySelectorAll('.schedule-checkbox');
            const idsInput   = form.querySelector('.selected-ids-input');
            const confirmBtn = form.querySelector('.confirm-book-btn');
            const countLabel = form.querySelector('.selection-count');

            function updateState() {
                const checked = Array.from(checkboxes).filter(c => c.checked);
                idsInput.value = checked.map(c => c.value).join(',');
                confirmBtn.disabled = checked.length === 0;
                countLabel.textContent = checked.length + ' session' + (checked.length !== 1 ? 's' : '') + ' selected';
            }

            checkboxes.forEach(function (cb) {
                cb.addEventListener('change', function () {
                    const label = cb.closest('.schedule-slot');
                    label.style.background  = cb.checked ? '#e8f4ff' : '';
                    label.style.borderColor = cb.checked ? '#0d6efd' : '';
                    updateState();
                });

                cb.closest('.schedule-slot').addEventListener('click', function (e) {
                    if (e.target !== cb) {
                        cb.checked = !cb.checked;
                        cb.dispatchEvent(new Event('change'));
                    }
                });
            });

            form.addEventListener('submit', function (e) {
                const checked = Array.from(checkboxes).filter(c => c.checked);
                if (checked.length === 0) { e.preventDefault(); return; }
                const noun = checked.length === 1 ? 'session' : 'sessions';
                if (!confirm('Book ' + checked.length + ' ' + noun + '? This cannot be undone.')) {
                    e.preventDefault();
                }
            });
        });

        // ── Star rating logic ────────────────────────────────────────────────
        document.querySelectorAll('.star-rating').forEach(function (container) {
            const trainerId  = container.dataset.trainerId;
            const stars      = container.querySelectorAll('.star-btn');
            const hiddenInput = document.querySelector('.star-value-input-' + trainerId);
            const label      = document.querySelector('.star-label-' + trainerId);
            const submitBtn  = document.querySelector('.submit-rating-btn-' + trainerId);
            const labels     = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];

            function paint(upTo) {
                stars.forEach(function (s, idx) {
                    s.className = 'bi ' + (idx < upTo ? 'bi-star-fill' : 'bi-star') + ' star-btn';
                    s.style.color = idx < upTo ? '#f5a623' : '#ccc';
                });
            }

            // Hover
            stars.forEach(function (star) {
                star.addEventListener('mouseenter', function () {
                    paint(parseInt(star.dataset.value));
                    label.textContent = labels[parseInt(star.dataset.value)];
                });
                star.addEventListener('mouseleave', function () {
                    const current = parseInt(hiddenInput.value) || 0;
                    paint(current);
                    label.textContent = current > 0 ? 'Your current rating: ' + current + '★' : 'Click a star to rate';
                });
                star.addEventListener('click', function () {
                    const val = parseInt(star.dataset.value);
                    hiddenInput.value = val;
                    paint(val);
                    label.textContent = labels[val] + ' (' + val + '★)';
                    submitBtn.disabled = false;
                });
            });
        });
    </script>
}
