@model IEnumerable<FLEXLINK.Models.ProfileTrainer>
@{
    ViewData["Title"] = "Our Trainers";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">Our Trainers</h2>
        <p class="text-muted">Choose a professional trainer to help you reach your fitness goals.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">No trainers are available yet. Check back soon!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var trainer in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">

                        @* Profile Picture *@
                        <div class="text-center pt-4">
                            <img src="@(trainer.ProfilePicture ?? "/uploads/DefaultProfile.png")"
                                 alt="@trainer.FullName"
                                 style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; border: 3px solid #dee2e6;" />
                        </div>

                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold mb-1">@trainer.FullName</h5>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-envelope"></i> @trainer.Email
                            </p>
                            @if (!string.IsNullOrEmpty(trainer.PhoneNumber))
                            {
                                <p class="text-muted small mb-1">
                                    <i class="bi bi-telephone"></i> @trainer.PhoneNumber
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(trainer.Address))
                            {
                                <p class="text-muted small mb-3">
                                    <i class="bi bi-geo-alt"></i> @trainer.Address
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(trainer.Expertise))
                            {
                                <p class="text-muted small mb-3">
                                    <i class="bi bi-trophy"></i> @trainer.Expertise
                                </p>
                            }

                            <button class="btn btn-primary w-100 mt-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#chooseTrainerModal"
                                    data-trainer-name="@trainer.FullName"
                                    data-trainer-id="@trainer.Id">
                                Choose Trainer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Confirm Modal *@
<div class="modal fade" id="chooseTrainerModal" tabindex="-1" aria-labelledby="chooseTrainerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="chooseTrainerModalLabel">Confirm Your Trainer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to choose <strong id="modalTrainerName"></strong> as your trainer?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmChooseBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Populate modal with the trainer's name when "Choose Trainer" is clicked
        const chooseModal = document.getElementById('chooseTrainerModal');
        chooseModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const trainerName = button.getAttribute('data-trainer-name');
            const trainerId = button.getAttribute('data-trainer-id');

            document.getElementById('modalTrainerName').textContent = trainerName;
            document.getElementById('confirmChooseBtn').setAttribute('data-trainer-id', trainerId);
        });

        // On Confirm — for now shows an alert (can be wired to a POST action later)
        document.getElementById('confirmChooseBtn').addEventListener('click', function () {
            const trainerId = this.getAttribute('data-trainer-id');
            alert('Trainer selected! (ID: ' + trainerId + ') — You can wire this to save the choice.');
            const modal = bootstrap.Modal.getInstance(document.getElementById('chooseTrainerModal'));
            modal.hide();
        });
    </script>
}
