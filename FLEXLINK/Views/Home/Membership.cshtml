@{
    ViewData["Title"] = "Membership Plans";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Choose Your Plan</h1>
        <p class="lead text-muted">Select the membership that fits your fitness goals.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 text-center">
                    <h4 class="my-0 fw-normal">Basic</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">$29<small class="text-muted fw-light">/mo</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><i class="bi bi-check2 text-success"></i> Access to Gym Floor</li>
                        <li><i class="bi bi-check2 text-success"></i> Standard Equipment</li>
                        <li><i class="bi bi-check2 text-success"></i> Locker Room Access</li>
                        <li class="text-muted text-decoration-line-through"><i class="bi bi-x text-danger"></i> Personal Training</li>
                    </ul>
                    <button type="button" class="btn btn-lg btn-outline-primary w-100">Get Started</button>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow border-primary border-2">
                <div class="card-header py-3 bg-primary text-white border-primary text-center">
                    <h4 class="my-0 fw-normal">Pro</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">$59<small class="text-muted fw-light">/mo</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><i class="bi bi-check2 text-success"></i> Everything in Basic</li>
                        <li><i class="bi bi-check2 text-success"></i> Group Classes</li>
                        <li><i class="bi bi-check2 text-success"></i> 24/7 Access</li>
                        <li><i class="bi bi-check2 text-success"></i> 1 Trainer Consultation</li>
                    </ul>
                    <button type="button" class="btn btn-lg btn-primary w-100">Most Popular</button>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 text-center">
                    <h4 class="my-0 fw-normal">Elite</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">$99<small class="text-muted fw-light">/mo</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><i class="bi bi-check2 text-success"></i> Everything in Pro</li>
                        <li><i class="bi bi-check2 text-success"></i> Unlimited Training</li>
                        <li><i class="bi bi-check2 text-success"></i> Sauna & Spa Access</li>
                        <li><i class="bi bi-check2 text-success"></i> Nutritional Coaching</li>
                    </ul>
                    <button type="button" class="btn btn-lg btn-outline-primary w-100">Go Elite</button>
                </div>
            </div>
        </div>
    </div>
</div>

